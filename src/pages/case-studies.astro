---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const title = "Case Studies & Capabilities — AI Automation | Sarasota Consulting";
const description = "See what's possible with AI automation. From our proven track record helping Sarasota businesses to cutting-edge capabilities like robot dog security patrols and AI-powered factory monitoring.";
const keywords = "AI case studies, business automation examples, robot dog security, AI perimeter security, automated accounting, document management AI, factory automation, Sarasota business success stories, AI ROI, process automation results";

const clientStories = [
  {
    tag: "Client Story — Financial Services",
    title: "From 3-Person Office to Sarasota's Largest Accounting Firm",
    image: null,
    challenge: "A small accounting practice with three employees was drowning in manual data entry, paper-based filing, and inefficient client communication. Tax season meant 80-hour weeks, and growth seemed impossible without proportionally growing staff.",
    solution: "We built an integrated suite of tools: document scanning and data extraction from client receipts and statements, automated categorization into accounting software, client portals for document upload, and streamlined tax preparation workflows.",
    results: [
      "Grew from 3 employees to one of Sarasota's largest firms",
      "Tax return preparation time dramatically reduced",
      "Client onboarding streamlined — from days to hours",
      "Paperless operations across all client accounts"
    ],
    quote: "We started with SarasotaConsulting when we were three people in a tiny office. Eventually we grew into one of Sarasota's largest accounting firms and all the IT and software consulting was provided by our friends at SarasotaConsulting.",
    label: "Accounting & Financial Services"
  },
  {
    tag: "Client Story — Document Management",
    title: "Intelligent Document Retrieval System",
    image: null,
    challenge: "A firm had decades of physical and digital documents scattered across filing cabinets, shared drives, and email inboxes. Finding a specific document could take hours. Important files were frequently misfiled or lost entirely.",
    solution: "We built a document management system that scanned, OCR'd, and categorized their entire archive. Staff could search for any document by describing what they needed. The system understood context and learned from user behavior over time.",
    results: [
      "Document retrieval time reduced from hours to seconds",
      "100% of physical archive digitized and searchable",
      "Eliminated misfiling and lost document incidents",
      "Recovered significant billable hours per employee per week"
    ],
    quote: "Our new document retrieval system saves us so much time and space. We are able to find data and information which was literally buried before.",
    label: "Document Management"
  },
  {
    tag: "Client Story — E-Commerce",
    title: "Amazon Automated Seller Engine",
    image: null,
    challenge: "An e-commerce business selling across multiple Amazon marketplaces was manually managing inventory, repricing, and order fulfillment. With thousands of SKUs, the owner spent 6+ hours daily on repetitive marketplace tasks.",
    solution: "We built an automated seller engine that monitors competitor pricing in real-time, dynamically adjusts prices, manages inventory across warehouses, and automates order routing and fulfillment notifications.",
    results: [
      "Significant increase in Buy Box win rate",
      "Daily manual work reduced from 6 hours to minutes",
      "Revenue increased substantially within 6 months",
      "Automated repricing runs 24/7 across all marketplaces"
    ],
    quote: "SarasotaConsulting listened and asked the right questions. 10 months later I was reaping the benefits of my software product.",
    label: "E-Commerce"
  },
  {
    tag: "Client Story — Membership & Payments",
    title: "Automated Membership Platform with Integrated Payments",
    image: null,
    challenge: "A community organization was managing memberships through spreadsheets and collecting dues via mailed checks. Renewal reminders were sent manually, resulting in high lapse rates.",
    solution: "We built a custom membership platform with automated online registration, integrated payment processing via Stripe, automated renewal reminders, member portals, and event management capabilities.",
    results: [
      "Membership lapse rate dropped dramatically",
      "Dues collection fully automated — zero manual processing",
      "Administrative time reduced by 90%",
      "Self-service portal eliminated most support requests"
    ],
    quote: "They did our website, helped us connect to online payment systems and built a membership platform specifically for our needs. Now the system is all automated.",
    label: "Non-Profit & Community Organizations"
  },
  {
    tag: "Client Story — Software Optimization",
    title: "Legacy Auction Platform Rescue & Optimization",
    image: null,
    challenge: "A company purchased auction software that couldn't handle their user load. During live auctions, the system would slow to a crawl or crash entirely — right when it mattered most.",
    solution: "Our team performed deep code analysis, identifying critical bottlenecks in database queries, real-time bid processing, and WebSocket connections. We rewrote the performance-critical paths, implemented caching layers, and added load balancing.",
    results: [
      "System handles 10x the concurrent users without slowdown",
      "Page load times reduced from seconds to milliseconds",
      "Zero crashes during live auctions",
      "Saved significant budget vs. rebuilding from scratch"
    ],
    quote: "We never thought anybody else could so quickly improve our product. The in-depth analysis and improvements were exactly what we needed.",
    label: "Auction & Marketplace Technology"
  }
];

const capabilities = [
  {
    tag: "Capability Showcase — Security & AI Robotics",
    title: "Autonomous Robot Dogs for Perimeter Security",
    image: "/images/case-robot-dog.png",
    description: "Traditional security guard services cost businesses $150,000-200,000+ annually, with inevitable coverage gaps during shift changes and human fatigue. AI-powered robotic security changes the equation entirely.",
    what: "We deploy fleets of AI-powered robot dogs equipped with thermal cameras, LiDAR, and real-time anomaly detection. Each unit autonomously patrols designated zones, identifies threats, and alerts a central monitoring dashboard. The AI learns normal activity patterns and flags deviations — a person lingering near a fence at 3 AM, an unfamiliar vehicle in a restricted area, or changes in environmental conditions.",
    potential: [
      "Up to 70% reduction in security costs vs. traditional guard services",
      "24/7 continuous coverage with zero fatigue or shift gaps",
      "High threat detection accuracy with minimal false positives",
      "Real-time alerts with HD video to security team's phones",
      "Complete patrol logs and audit trails for compliance"
    ],
    label: "Commercial Property Management"
  },
  {
    tag: "Capability Showcase — Industrial IoT",
    title: "Real-Time Factory Monitoring with Sensor AI",
    image: "/images/case-factory.png",
    description: "Manufacturing facilities lose tens of thousands in unplanned downtime every year. Operators walking the floor with clipboards can't catch problems before they cascade. AI-powered monitoring changes reactive maintenance into predictive intelligence.",
    what: "We deploy IoT sensors across critical equipment, feeding data into an AI-powered monitoring platform. The system performs continuous vibration analysis, temperature tracking, and anomaly detection. Machine learning models can predict equipment failures days before they occur, and automated alerts trigger maintenance workflows before anything breaks.",
    potential: [
      "Dramatic reduction in unplanned equipment downtime",
      "Predictive maintenance alerts days before failure occurs",
      "Real-time dashboards accessible from any device, anywhere",
      "Automated compliance reporting with one click",
      "Typical ROI achieved within months of deployment"
    ],
    label: "Manufacturing & Industrial"
  }
];
---
<Layout title={title} description={description} keywords={keywords} canonicalUrl="/case-studies" ogType="article">
  <Nav />

  <!-- Hero -->
  <section class="relative py-32 grid-bg overflow-hidden">
    <div class="absolute top-1/3 left-1/4 w-96 h-96 bg-accent/15 rounded-full blur-3xl"></div>
    <div class="relative max-w-7xl mx-auto px-6 text-center">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass text-sm text-accent-light mb-8 animate-fade-up">
        Proven Results & Next-Gen Capabilities
      </span>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black leading-tight tracking-tight animate-fade-up-delay-1">
        Case Studies & <span class="gradient-text">Capabilities</span>
      </h1>
      <p class="mt-6 text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed animate-fade-up-delay-2">
        Since 2012, we've helped Sarasota businesses transform their operations. Now, with AI, the possibilities are even bigger.
      </p>
    </div>
  </section>

  <!-- Client Stories -->
  <section class="py-24">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="text-accent text-sm font-semibold uppercase tracking-widest">Proven Track Record</span>
        <h2 class="text-4xl sm:text-5xl font-bold mt-4">
          Client <span class="gradient-text">Success Stories</span>
        </h2>
        <p class="mt-4 text-gray-400 text-lg">Real projects delivered for real Sarasota businesses.</p>
      </div>

      <div class="space-y-12">
        {clientStories.map((cs, i) => (
          <article class="glass rounded-3xl overflow-hidden" id={`client-${i + 1}`}>
            <div class="p-8 md:p-12">
              <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider bg-accent/20 text-accent-light mb-6">
                {cs.tag}
              </span>

              <h3 class="text-3xl font-bold">{cs.title}</h3>

              <div class="mt-8">
                <h4 class="text-sm font-semibold uppercase tracking-widest text-red-400 mb-3">The Challenge</h4>
                <p class="text-gray-400 text-lg leading-relaxed">{cs.challenge}</p>
              </div>

              <div class="mt-8">
                <h4 class="text-sm font-semibold uppercase tracking-widest text-accent mb-3">What We Built</h4>
                <p class="text-gray-400 text-lg leading-relaxed">{cs.solution}</p>
              </div>

              <div class="mt-8">
                <h4 class="text-sm font-semibold uppercase tracking-widest text-green-400 mb-4">Results</h4>
                <div class="grid sm:grid-cols-2 gap-3">
                  {cs.results.map((result: string) => (
                    <div class="flex items-start gap-3 bg-white/5 rounded-xl p-4">
                      <svg class="w-5 h-5 text-green-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
                      </svg>
                      <span class="text-gray-300 text-sm">{result}</span>
                    </div>
                  ))}
                </div>
              </div>

              <div class="mt-8 border-l-4 border-accent/50 pl-6 py-2">
                <p class="text-gray-300 italic text-lg leading-relaxed">"{cs.quote}"</p>
                <span class="text-accent text-sm font-semibold mt-2 block">{cs.label}</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Capability Showcases -->
  <section class="py-24 relative">
    <div class="absolute inset-0 grid-bg"></div>
    <div class="relative max-w-5xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="text-accent text-sm font-semibold uppercase tracking-widest">What's Possible Now</span>
        <h2 class="text-4xl sm:text-5xl font-bold mt-4">
          Next-Gen <span class="gradient-text">Capabilities</span>
        </h2>
        <p class="mt-4 text-gray-400 text-lg">Cutting-edge AI solutions we're ready to deploy for your business.</p>
      </div>

      <div class="space-y-16">
        {capabilities.map((cap, i) => (
          <article class="glass rounded-3xl overflow-hidden" id={`capability-${i + 1}`}>
            {cap.image && (
              <div class="relative h-64 md:h-80 overflow-hidden">
                <img src={cap.image} alt={cap.title} class="w-full h-full object-cover" />
                <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/30 to-transparent"></div>
                <div class="absolute bottom-6 left-8">
                  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider bg-accent/30 text-accent-light backdrop-blur-sm">
                    {cap.tag}
                  </span>
                </div>
              </div>
            )}

            <div class="p-8 md:p-12">
              {!cap.image && (
                <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider bg-accent/20 text-accent-light mb-6">
                  {cap.tag}
                </span>
              )}

              <h3 class="text-3xl sm:text-4xl font-bold">{cap.title}</h3>

              <div class="mt-6">
                <p class="text-gray-400 text-lg leading-relaxed">{cap.description}</p>
              </div>

              <div class="mt-8">
                <h4 class="text-sm font-semibold uppercase tracking-widest text-accent mb-3">How It Works</h4>
                <p class="text-gray-400 text-lg leading-relaxed">{cap.what}</p>
              </div>

              <div class="mt-8">
                <h4 class="text-sm font-semibold uppercase tracking-widest text-green-400 mb-4">Expected Outcomes</h4>
                <div class="grid sm:grid-cols-2 gap-3">
                  {cap.potential.map((result: string) => (
                    <div class="flex items-start gap-3 bg-white/5 rounded-xl p-4">
                      <svg class="w-5 h-5 text-green-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
                      </svg>
                      <span class="text-gray-300 text-sm">{result}</span>
                    </div>
                  ))}
                </div>
              </div>

              <div class="mt-8">
                <a href="/#contact" class="inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-white px-6 py-3 rounded-xl font-semibold transition-all hover:shadow-lg hover:shadow-accent/25">
                  Explore This Solution
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-accent/10 via-purple-500/5 to-transparent"></div>
    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-4xl sm:text-5xl font-bold">
        Your Story <span class="gradient-text">Starts Here</span>
      </h2>
      <p class="mt-6 text-xl text-gray-400">
        Every success story above started with a single conversation. Let's have yours.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#contact" class="bg-accent hover:bg-accent-dark text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all hover:shadow-xl hover:shadow-accent/25">
          Get Your Free Automation Audit
        </a>
        <a href="/openclaw" class="glass hover:bg-white/10 text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all">
          Explore OpenClaw
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
