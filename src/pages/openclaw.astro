---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const title = "OpenClaw — AI Agent Platform for Business Automation | Sarasota Consulting";
const description = "OpenClaw is our open-source AI agent platform that automates business processes, handles customer interactions, manages workflows, and integrates with your existing tools. Built for Sarasota businesses ready to scale.";
const keywords = "OpenClaw, AI agent platform, business automation, AI agents, workflow automation, open source AI, Sarasota automation, intelligent agents, business process automation, customer engagement AI, OpenClaw platform";

const features = [
  {
    title: "Autonomous AI Agents",
    description: "Deploy intelligent agents that understand your business context. They read emails, process documents, update databases, and make decisions — just like a team member, but available 24/7.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"/></svg>`
  },
  {
    title: "Natural Language Control",
    description: "No coding required for your team. Tell OpenClaw what you need in plain English: 'Send a follow-up email to every lead who hasn't responded in 3 days.' It just works.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>`
  },
  {
    title: "Deep System Integration",
    description: "OpenClaw connects to everything — your CRM, email, calendar, accounting software, inventory systems, payment processors. One unified brain for your entire operation.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>`
  },
  {
    title: "Learning & Adapting",
    description: "The more OpenClaw works with your business, the smarter it gets. It learns your preferences, your customers' patterns, and your industry's nuances to deliver increasingly better results.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/></svg>`
  },
  {
    title: "Transparent & Open Source",
    description: "Built on open-source principles. You own your data, your workflows, and your automations. No vendor lock-in. No black boxes. Full transparency into how your AI agents operate.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`
  },
  {
    title: "Enterprise-Grade Security",
    description: "Your business data stays yours. OpenClaw runs in secure environments with encryption at rest and in transit, role-based access controls, and full audit logging.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`
  }
];

const useCases = [
  {
    title: "Customer Service Automation",
    description: "AI agents that handle customer inquiries via email, chat, and phone — escalating to humans only when truly needed.",
    metric: "80% of inquiries handled automatically"
  },
  {
    title: "Lead Qualification & Outreach",
    description: "Automatically research prospects, personalize outreach emails, follow up on schedule, and route qualified leads to your sales team.",
    metric: "3x more qualified leads per week"
  },
  {
    title: "Document Processing",
    description: "Extract data from invoices, contracts, forms, and reports. Automatically file, categorize, and route documents to the right people.",
    metric: "90% reduction in manual data entry"
  },
  {
    title: "Inventory & Order Management",
    description: "Monitor stock levels, predict reorder points, generate purchase orders, and sync across multiple sales channels automatically.",
    metric: "Zero stockouts, 40% less overstock"
  }
];
---
<Layout title={title} description={description} keywords={keywords} canonicalUrl="/openclaw">
  <Nav />

  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center grid-bg overflow-hidden">
    <div class="absolute top-1/3 -left-32 w-96 h-96 bg-accent/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-purple-500/15 rounded-full blur-3xl"></div>

    <div class="relative max-w-7xl mx-auto px-6 py-32">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass text-sm text-accent-light mb-8 animate-fade-up">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
          Open Source AI Agent Platform
        </span>

        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black leading-tight tracking-tight animate-fade-up-delay-1">
          Meet <span class="gradient-text">OpenClaw</span>
        </h1>

        <p class="mt-6 text-xl text-gray-400 leading-relaxed animate-fade-up-delay-2">
          The AI agent platform that doesn't just answer questions — it <em>does the work</em>.
          OpenClaw deploys autonomous AI agents that integrate with your business systems,
          understand your processes, and execute tasks end-to-end.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 animate-fade-up-delay-3">
          <a href="/#contact" class="bg-accent hover:bg-accent-dark text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all hover:shadow-xl hover:shadow-accent/25">
            Deploy OpenClaw for Your Business
          </a>
          <a href="/case-studies" class="glass hover:bg-white/10 text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all">
            See It in Action
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- What is OpenClaw -->
  <section class="py-24 relative">
    <div class="max-w-7xl mx-auto px-6">
      <div class="glass rounded-3xl p-12 md:p-16">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl sm:text-4xl font-bold">
              Not Another Chatbot.<br />
              <span class="gradient-text">A Digital Workforce.</span>
            </h2>
            <p class="mt-6 text-gray-400 text-lg leading-relaxed">
              Most "AI tools" give you a chat window and call it a day. OpenClaw is fundamentally different.
              It's a platform for deploying AI agents that operate autonomously within your business —
              reading your emails, updating your spreadsheets, following up with customers, generating reports,
              and executing multi-step workflows without human intervention.
            </p>
            <p class="mt-4 text-gray-400 text-lg leading-relaxed">
              Think of it as hiring a team of tireless, intelligent assistants who already know
              every tool your business uses.
            </p>
          </div>
          <div class="space-y-4">
            <div class="glass rounded-xl p-6">
              <div class="text-3xl font-bold gradient-text">500+</div>
              <div class="text-gray-400 mt-1">Integrations Available</div>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div class="glass rounded-xl p-6">
                <div class="text-3xl font-bold gradient-text">&lt;5min</div>
                <div class="text-gray-400 mt-1">Setup Time</div>
              </div>
              <div class="glass rounded-xl p-6">
                <div class="text-3xl font-bold gradient-text">99.9%</div>
                <div class="text-gray-400 mt-1">Uptime</div>
              </div>
            </div>
            <div class="glass rounded-xl p-6">
              <div class="text-3xl font-bold gradient-text">Open Source</div>
              <div class="text-gray-400 mt-1">Fully transparent. No vendor lock-in.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-24 relative">
    <div class="absolute inset-0 grid-bg"></div>
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="text-accent text-sm font-semibold uppercase tracking-widest">Platform Capabilities</span>
        <h2 class="text-4xl sm:text-5xl font-bold mt-4">
          Built for <span class="gradient-text">Real Work</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((feature) => (
          <div class="glass rounded-2xl p-8 hover:bg-white/10 transition-all duration-300 group hover:-translate-y-1">
            <div class="text-accent mb-4 group-hover:scale-110 transition-transform" set:html={feature.icon} />
            <h3 class="text-xl font-bold mb-3">{feature.title}</h3>
            <p class="text-gray-400 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="text-accent text-sm font-semibold uppercase tracking-widest">Use Cases</span>
        <h2 class="text-4xl sm:text-5xl font-bold mt-4">
          What OpenClaw Can <span class="gradient-text">Do For You</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {useCases.map((uc) => (
          <div class="glass rounded-2xl p-8 hover:bg-white/10 transition-all duration-300">
            <h3 class="text-xl font-bold mb-3">{uc.title}</h3>
            <p class="text-gray-400 leading-relaxed mb-4">{uc.description}</p>
            <span class="inline-flex items-center gap-2 text-accent font-semibold text-sm">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
              {uc.metric}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-accent/10 via-purple-500/5 to-transparent"></div>
    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-4xl sm:text-5xl font-bold">
        Ready to Deploy <span class="gradient-text">OpenClaw</span>?
      </h2>
      <p class="mt-6 text-xl text-gray-400">
        Let us set up OpenClaw for your business. We handle the integration, training, and deployment — you enjoy the results.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#contact" class="bg-accent hover:bg-accent-dark text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all hover:shadow-xl hover:shadow-accent/25">
          Schedule a Demo
        </a>
        <a href="/case-studies" class="glass hover:bg-white/10 text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all">
          Read Case Studies
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
