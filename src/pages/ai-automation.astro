---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const title = "AI-Powered Systems Automation — Claude Code, Codex & Beyond | Sarasota Consulting";
const description = "Bring the power of AI coding agents like Claude Code and Codex into your business systems. Automate software development, data pipelines, reporting, and IT operations with cutting-edge AI.";
const keywords = "Claude Code, AI coding agent, Codex, systems automation, AI software development, automated coding, business IT automation, Sarasota AI, AI engineering, code generation, automated testing, AI DevOps, intelligent automation";

const capabilities = [
  {
    title: "Automated Code Generation",
    description: "AI agents that write, test, and deploy production-ready code. From API integrations to data processing scripts — describe what you need, and the AI builds it.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>`
  },
  {
    title: "Legacy System Modernization",
    description: "Got systems running on outdated tech? AI agents analyze your existing codebase, understand the business logic, and help migrate to modern frameworks — safely and incrementally.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg>`
  },
  {
    title: "Intelligent Data Pipelines",
    description: "Build automated data flows that extract, transform, and load your business data. AI handles the edge cases, data cleaning, and error recovery that break traditional ETL.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"/></svg>`
  },
  {
    title: "Automated Testing & QA",
    description: "AI writes comprehensive test suites for your software, identifies bugs before they reach production, and continuously monitors code quality as your systems evolve.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>`
  },
  {
    title: "DevOps & Infrastructure",
    description: "AI manages your cloud infrastructure, deploys updates, monitors performance, and auto-scales resources. Your systems stay healthy without a dedicated ops team.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z"/></svg>`
  },
  {
    title: "Custom API Development",
    description: "Need to connect systems that don't talk to each other? AI agents build custom APIs, webhooks, and middleware that bridge your tools into one seamless ecosystem.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>`
  }
];
---
<Layout title={title} description={description} keywords={keywords} canonicalUrl="/ai-automation">
  <Nav />

  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/ai-automation-hero.png" alt="Holographic code streaming" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-primary/90 via-primary/75 to-primary/60"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-6 py-32">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass text-sm text-cyan-400 mb-8 animate-fade-up">
          <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span>
          Next-Generation AI Engineering
        </span>

        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black leading-tight tracking-tight animate-fade-up-delay-1">
          AI That <span class="gradient-text">Writes Code</span> For Your Business
        </h1>

        <p class="mt-6 text-xl text-gray-400 leading-relaxed animate-fade-up-delay-2">
          Claude Code and Codex represent a paradigm shift in how software gets built.
          Instead of hiring developers for every integration, report, or automation — AI agents
          write production-grade code in minutes, not weeks.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 animate-fade-up-delay-3">
          <a href="/#contact" class="bg-accent hover:bg-accent-dark text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all hover:shadow-xl hover:shadow-accent/25">
            See What AI Can Build
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- The Shift -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="glass rounded-3xl p-12 md:p-16">
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <div>
            <span class="text-accent text-sm font-semibold uppercase tracking-widest">The New Reality</span>
            <h2 class="text-3xl sm:text-4xl font-bold mt-4">
              Software Development<br />
              <span class="gradient-text">Has Changed Forever</span>
            </h2>
            <p class="mt-6 text-gray-400 text-lg leading-relaxed">
              A year ago, building a custom integration between your CRM and accounting system
              meant hiring a developer for weeks. Today, an AI coding agent like Claude Code
              can analyze both systems, write the integration, test it, and deploy it — often
              in a single afternoon.
            </p>
            <p class="mt-4 text-gray-400 text-lg leading-relaxed">
              We bring this capability to Sarasota businesses. Whether you need a one-off
              automation or an entirely new system, AI-powered development gets you there
              10x faster and at a fraction of the cost.
            </p>
          </div>
          <div class="space-y-4">
            <div class="glass rounded-xl p-6 border-l-4 border-red-500/50">
              <h4 class="font-bold text-gray-300">Traditional Development</h4>
              <ul class="mt-3 space-y-2 text-gray-500 text-sm">
                <li class="flex items-center gap-2"><span class="text-red-400">x</span> Weeks to scope and estimate</li>
                <li class="flex items-center gap-2"><span class="text-red-400">x</span> $10k-50k+ per project</li>
                <li class="flex items-center gap-2"><span class="text-red-400">x</span> Months of development time</li>
                <li class="flex items-center gap-2"><span class="text-red-400">x</span> Ongoing maintenance burden</li>
              </ul>
            </div>
            <div class="glass rounded-xl p-6 border-l-4 border-green-500/50">
              <h4 class="font-bold text-gray-300">AI-Powered Development</h4>
              <ul class="mt-3 space-y-2 text-gray-500 text-sm">
                <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Hours to prototype and deploy</li>
                <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> 80-90% cost reduction</li>
                <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Days, not months</li>
                <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> AI handles maintenance too</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="py-24 relative">
    <div class="absolute inset-0 grid-bg"></div>
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="text-accent text-sm font-semibold uppercase tracking-widest">Capabilities</span>
        <h2 class="text-4xl sm:text-5xl font-bold mt-4">
          What AI Engineering <span class="gradient-text">Delivers</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {capabilities.map((cap) => (
          <div class="glass rounded-2xl p-8 hover:bg-white/10 transition-all duration-300 group hover:-translate-y-1">
            <div class="text-accent mb-4 group-hover:scale-110 transition-transform" set:html={cap.icon} />
            <h3 class="text-xl font-bold mb-3">{cap.title}</h3>
            <p class="text-gray-400 leading-relaxed">{cap.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How We Use It -->
  <section class="py-24">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="text-accent text-sm font-semibold uppercase tracking-widest">Our Approach</span>
        <h2 class="text-4xl sm:text-5xl font-bold mt-4">
          Human Expertise + <span class="gradient-text">AI Speed</span>
        </h2>
      </div>

      <div class="space-y-8">
        <div class="glass rounded-2xl p-8 md:p-12">
          <div class="flex items-start gap-6">
            <div class="text-4xl font-black gradient-text flex-shrink-0">1</div>
            <div>
              <h3 class="text-2xl font-bold">We Architect, AI Builds</h3>
              <p class="mt-3 text-gray-400 text-lg leading-relaxed">
                Our senior engineers design the architecture and define the requirements.
                Then AI coding agents generate the implementation — clean, tested, production-ready code.
                We review everything before it touches your systems.
              </p>
            </div>
          </div>
        </div>

        <div class="glass rounded-2xl p-8 md:p-12">
          <div class="flex items-start gap-6">
            <div class="text-4xl font-black gradient-text flex-shrink-0">2</div>
            <div>
              <h3 class="text-2xl font-bold">Continuous AI Maintenance</h3>
              <p class="mt-3 text-gray-400 text-lg leading-relaxed">
                Once deployed, AI agents continuously monitor your systems for issues,
                apply security patches, optimize performance, and adapt to changing requirements.
                Your software stays current without constant developer attention.
              </p>
            </div>
          </div>
        </div>

        <div class="glass rounded-2xl p-8 md:p-12">
          <div class="flex items-start gap-6">
            <div class="text-4xl font-black gradient-text flex-shrink-0">3</div>
            <div>
              <h3 class="text-2xl font-bold">You Own Everything</h3>
              <p class="mt-3 text-gray-400 text-lg leading-relaxed">
                All code, documentation, and infrastructure is yours. No proprietary platforms,
                no lock-in. We build on open standards and give you full access to everything.
                If you ever want to bring development in-house, you can.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/10 via-accent/5 to-transparent"></div>
    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-4xl sm:text-5xl font-bold">
        Let AI Build <span class="gradient-text">Your Next System</span>
      </h2>
      <p class="mt-6 text-xl text-gray-400">
        Tell us what you need automated. We'll show you how AI can build it in days, not months.
      </p>
      <a href="/#contact" class="inline-block mt-10 bg-accent hover:bg-accent-dark text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all hover:shadow-xl hover:shadow-accent/25">
        Start a Conversation
      </a>
    </div>
  </section>

  <Footer />
</Layout>
