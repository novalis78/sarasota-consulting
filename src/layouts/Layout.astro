---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sarasota Consulting | AI-Powered Business Automation",
  description = "We help Sarasota businesses save time and increase revenue with AI automation, intelligent workflows, and custom software solutions."
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="author" content="Sarasota Consulting" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <title>{title}</title>
</head>
<body class="bg-primary text-white overflow-x-hidden">
  <slot />
</body>
</html>
