---
const testimonials = [
  {
    quote: "SarasotaConsulting completely changed the way we run our office. Our new document retrieval system saves us so much time and space. We are able to find data and information which was literally buried before.",
    industry: "Document Management"
  },
  {
    quote: "I had this product idea. SarasotaConsulting listened and asked the right questions. 10 months later I was reaping the benefits of my software product and knew I had a reliable local IT company to support my future ideas.",
    industry: "Product Development"
  },
  {
    quote: "They did our website, helped us connect to online payment systems and built a membership platform specifically for our needs. Now the system is all automated and we can focus on our members.",
    industry: "Membership Platform"
  },
  {
    quote: "We started our work with SarasotaConsulting when we were three people in a tiny office. Eventually we grew into one of Sarasota's largest accounting firms — all the IT and software consulting was provided by our friends at SarasotaConsulting.",
    industry: "Accounting"
  },
  {
    quote: "SarasotaConsulting built an online reporting and analysis website tracking our factory data. Beautiful charts, reports with the click of one button — the whole package. Now we can keep track of our plant from anywhere.",
    industry: "Industrial Monitoring"
  },
  {
    quote: "We got auction software which did not run properly. SarasotaConsulting did an in-depth analysis and helped us with load tests and code improvements. We never thought anybody could so quickly improve our product.",
    industry: "Software Analysis"
  }
];
---
<section id="results" class="py-24 relative">
  <div class="absolute inset-0 grid-bg"></div>
  <div class="relative max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="text-accent text-sm font-semibold uppercase tracking-widest">Client Results</span>
      <h2 class="text-4xl sm:text-5xl font-bold mt-4">
        Trusted by <span class="gradient-text">Sarasota Businesses</span>
      </h2>
      <p class="mt-4 text-gray-400 text-lg">Real results from real local businesses we've helped transform.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="glass rounded-2xl p-8 hover:bg-white/10 transition-all duration-300">
          <div class="flex gap-1 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-gray-300 leading-relaxed italic">"{t.quote}"</p>
          <div class="mt-6 pt-4 border-t border-white/10">
            <span class="text-accent text-sm font-semibold">{t.industry}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
