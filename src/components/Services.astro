---
<section id="services" class="py-24 relative">
  <div class="absolute inset-0 grid-bg"></div>
  <div class="relative max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="text-accent text-sm font-semibold uppercase tracking-widest">What We Do</span>
      <h2 class="text-4xl sm:text-5xl font-bold mt-4">
        AI That Works <span class="gradient-text">For You</span>
      </h2>
      <p class="mt-4 text-gray-400 max-w-2xl mx-auto text-lg">
        We don't just talk about AI — we deploy it. Real automations that save real hours and generate real revenue.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <div class="glass rounded-2xl p-8 hover:bg-white/10 transition-all duration-300 group hover:-translate-y-1">
          <div class="text-accent mb-4 group-hover:scale-110 transition-transform" set:html={service.icon} />
          <h3 class="text-xl font-bold mb-3">{service.title}</h3>
          <p class="text-gray-400 leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
