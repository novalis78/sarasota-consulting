---
---
<section class="relative min-h-screen flex items-center justify-center grid-bg overflow-hidden">
  <!-- Gradient orbs -->
  <div class="absolute top-1/4 -left-32 w-96 h-96 bg-accent/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-purple-500/15 rounded-full blur-3xl"></div>

  <div class="relative max-w-7xl mx-auto px-6 py-32 text-center">
    <div class="animate-fade-up">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass text-sm text-accent-light mb-8">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
        Serving Sarasota Since 2012 — Now AI-Powered
      </span>
    </div>

    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black leading-tight tracking-tight animate-fade-up-delay-1">
      Stop Wasting Time.<br />
      <span class="gradient-text">Start Automating.</span>
    </h1>

    <p class="mt-6 text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed animate-fade-up-delay-2">
      We identify the painful, repetitive processes bleeding your business dry &mdash; and replace them with intelligent AI systems that work 24/7.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center animate-fade-up-delay-3">
      <a href="#contact" class="bg-accent hover:bg-accent-dark text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all hover:shadow-xl hover:shadow-accent/25 hover:-translate-y-0.5">
        Free Automation Audit
      </a>
      <a href="#process" class="glass hover:bg-white/10 text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all">
        See How It Works
      </a>
    </div>

    <!-- Stats bar -->
    <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto">
      <div class="glass rounded-xl p-4">
        <div class="text-3xl font-bold gradient-text">Since '12</div>
        <div class="text-sm text-gray-400 mt-1">Est. 2012 in Sarasota</div>
      </div>
      <div class="glass rounded-xl p-4">
        <div class="text-3xl font-bold gradient-text">100+</div>
        <div class="text-sm text-gray-400 mt-1">Projects Delivered</div>
      </div>
      <div class="glass rounded-xl p-4">
        <div class="text-3xl font-bold gradient-text">10x</div>
        <div class="text-sm text-gray-400 mt-1">Efficiency Gains</div>
      </div>
      <div class="glass rounded-xl p-4">
        <div class="text-3xl font-bold gradient-text">24/7</div>
        <div class="text-sm text-gray-400 mt-1">AI Never Sleeps</div>
      </div>
    </div>
  </div>
</section>
